# ──────────────────────────────────────────────────────────────────────────
# ForgeSpecs environment configuration
# Copy to `.env` and fill in. Validated by packages/config (zod).
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# Postgres + pgvector. In docker-compose the host is `postgres`.
DATABASE_URL=postgresql://forgespecs:forgespecs@localhost:5432/forgespecs?schema=public

# AI — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI model aliases (optional overrides; sane OpenRouter defaults if unset).
# smart = chat/generation/refine; fast = cheap/low-latency; embed = embeddings.
# AI_MODEL_SMART=anthropic/claude-sonnet-4
# AI_MODEL_FAST=openai/gpt-4o-mini
# AI_MODEL_EMBED=openai/text-embedding-3-small

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# OAuth — GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public base URL of the web app
APP_URL=http://localhost:3000

# Collab (Yjs websocket server)
COLLAB_PORT=1234
# Browser-facing collab websocket URL (the web client connects here directly).
# Public (NEXT_PUBLIC_*) so it is inlined into the client bundle at build time.
NEXT_PUBLIC_COLLAB_URL=ws://localhost:1234

# Redis — BullMQ jobs / rate limit / collab backplane. Host is `redis` in compose.
# OPTIONAL and intentionally has NO default: when UNSET, background jobs
# (embedding + AI generation) run INLINE in-process, rate limiting uses an
# in-memory token bucket, and the collab backplane stays single-replica — dev and
# `next build` work with no Redis (and produce NO connection errors). Set it to
# enable BullMQ workers + a shared cross-replica rate limiter. AI generation jobs
# are crash-safe + resumable regardless (progress persists on generation_job).
# REDIS_URL=redis://localhost:6379
# DISABLE_REDIS=1             # force inline even if REDIS_URL is set
# JOBS_CONCURRENCY=4          # embedding worker concurrency
# GENERATION_CONCURRENCY=2    # architecture-generation worker concurrency (web process)

# ──────────────────────────────────────────────────────────────────────────
# M11 — Enterprise (all OPTIONAL; absent features degrade gracefully)
# ──────────────────────────────────────────────────────────────────────────

# Multi-replica collab backplane (Yjs awareness/update fan-out over Redis pub/sub).
# Requires REDIS_URL set AND >1 collab replica. Off by default (single-replica).
# COLLAB_REDIS_BACKPLANE=1

# OIDC SSO (e.g. Okta, Entra ID, Auth0, Keycloak). All five required to enable.
# The issuer's /.well-known/openid-configuration is used for endpoint discovery.
# SSO_OIDC_PROVIDER_ID=okta            # stable id used in /sign-in/sso?providerId=
# SSO_OIDC_ISSUER=https://your-org.okta.com
# SSO_OIDC_CLIENT_ID=your-oidc-client-id
# SSO_OIDC_CLIENT_SECRET=your-oidc-client-secret
# SSO_OIDC_DOMAIN=your-company.com     # email domain auto-routed to this provider

# SAML SSO (fiddly + IdP-specific — needs live IdP testing). All five required.
# SSO_SAML_PROVIDER_ID=saml
# SSO_SAML_ISSUER=https://your-idp/entity-id
# SSO_SAML_ENTRY_POINT=https://your-idp/sso/saml
# SSO_SAML_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# SSO_SAML_DOMAIN=your-company.com

# GitHub PR linkage webhook. Set the same secret in the GitHub App/repo webhook
# (Content type: application/json, events: Pull requests). Absent → endpoint 503s.
# GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Repo ingest (M12). CSV of absolute paths under which a LOCAL ingest is allowed.
# Empty → local mode disabled. The docker-compose `app` service sets this to
# /repo and mounts the workspace there read-only.
# INGEST_LOCAL_ALLOWED_ROOTS=/repo
# Aggregate byte cap for the fetch + walk (default 100 MiB).
# INGEST_MAX_BYTES=104857600
